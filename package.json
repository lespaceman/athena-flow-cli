{
	"name": "@athenaflow/cli",
	"description": "Workflow runtime for Claude Code with hooks, plugins, and interactive terminal observability",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lespaceman/athena-flow-cli.git"
	},
	"homepage": "https://github.com/lespaceman/athena-flow-cli#readme",
	"bugs": {
		"url": "https://github.com/lespaceman/athena-flow-cli/issues"
	},
	"keywords": [
		"cli",
		"claude",
		"terminal",
		"ink",
		"hooks",
		"dashboard"
	],
	"version": "0.3.21",
	"license": "MIT",
	"bin": {
		"athena": "dist/cli.js",
		"athena-flow": "dist/cli.js",
		"athena-hook-forwarder": "dist/hook-forwarder.js"
	},
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"dev": "tsup --watch",
		"start": "tsup && node dist/cli.js",
		"dev:debug": "tsup && DEV=true node dist/cli.js",
		"devtools": "ELECTRON_DISABLE_SANDBOX=1 react-devtools",
		"perf:tui": "node scripts/perf-runner.mjs --mode=full",
		"perf:cpu": "node scripts/perf-runner.mjs --mode=cpu --no-app-profile",
		"perf:trace": "node scripts/perf-runner.mjs --mode=trace --no-app-profile",
		"perf:heap": "node scripts/perf-runner.mjs --mode=heap --no-app-profile",
		"perf:summary": "node scripts/perf-summary.mjs",
		"protocol:codex": "node scripts/update-codex-protocol-snapshot.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint:format": "git ls-files -z | xargs -0 prettier --check --ignore-unknown",
		"lint:eslint": "eslint .",
		"lint:staged": "lint-staged",
		"lint:dead": "knip --strict --exclude dependencies,unlisted,binaries",
		"lint": "npm run lint:format && npm run lint:eslint",
		"format": "prettier --write .",
		"prepare": "simple-git-hooks",
		"prepublishOnly": "npm run lint && npm run typecheck && npm run lint:dead && npm test && npm run build"
	},
	"files": [
		"dist",
		"!dist/**/*.js.map"
	],
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"better-sqlite3": "^12.6.2",
		"cli-highlight": "^2.1.11",
		"cli-table3": "^0.6.5",
		"ink": "^6.8.0",
		"marked": "^15.0.12",
		"marked-terminal": "^7.3.0",
		"meow": "^14.1.0",
		"posthog-node": "^5.28.0",
		"react": "^19.0.0",
		"react-dom": "^19.2.4",
		"use-context-selector": "^1.4.4"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@eslint/js": "^9.0.0",
		"@testing-library/react": "^16.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/marked-terminal": "^6.1.1",
		"@types/node": "^25.0.10",
		"@types/react": "^19.0.0",
		"@vdemedes/prettier-config": "^2.0.1",
		"chalk": "^5.3.0",
		"eslint": "^9.0.0",
		"eslint-plugin-react": "^7.37.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"ink-testing-library": "^4.0.0",
		"jsdom": "^27.4.0",
		"knip": "^5.85.0",
		"lint-staged": "^16.3.2",
		"prettier": "^3.0.0",
		"react-devtools": "^6.1.5",
		"react-devtools-core": "^6.1.5",
		"simple-git-hooks": "^2.13.1",
		"tsup": "^8.5.1",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.0.0",
		"vitest": "^3.0.0"
	},
	"simple-git-hooks": {
		"pre-commit": "npm run lint:staged",
		"commit-msg": "npx --no -- commitlint --edit $1"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": "prettier --write"
	},
	"prettier": "@vdemedes/prettier-config"
}
